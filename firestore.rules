rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // All collections: authenticated users can read and write.
    // Fine-grained authorization is enforced in server-side API routes
    // (which use the Admin SDK and bypass these rules entirely).
    match /{collection}/{docId} {
      allow read, write: if request.auth != null;
    }

    // Subcollections (e.g. lessons under courses)
    match /{collection}/{docId}/{sub}/{subId} {
      allow read, write: if request.auth != null;
    }
  }
}
