# === Supply Chain Security ===
# Block lifecycle scripts from running during install.
# This prevents malicious postinstall/preinstall scripts from executing code.
# If a legitimate package needs lifecycle scripts, explicitly allow it with:
#   npm install <pkg> --ignore-scripts=false
ignore-scripts=true

# Require exact versions when saving (no ^ or ~ prefix)
save-exact=true

# Generate lockfile for deterministic installs
package-lock=true
